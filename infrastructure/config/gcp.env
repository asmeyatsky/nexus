# GCP Infrastructure Configuration
# Nexus CRM - Salesforce Replacement on Google Cloud Platform

## Architecture Overview
# - GKE (Google Kubernetes Engine) for container orchestration
# - Cloud SQL (PostgreSQL) for primary database
# - Cloud Storage for file attachments
# - Vertex AI for AI capabilities
# - BigQuery for analytics
# - Cloud CDN for caching
# - Cloud Armor for security

## Environment Variables
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@/${DB_NAME}?host=/cloudsql/${PROJECT}:${REGION}:${INSTANCE}
GCP_PROJECT=your-project-id
GCP_REGION=europe-west2
GCP_ZONE=europe-west2-a

## Cloud SQL Configuration
DB_INSTANCE=nexus-crm-db
DB_NAME=nexus_crm
DB_USER=nexus_user

## GKE Configuration
GKE_CLUSTER=nexus-crm-cluster
GKE_NODE_COUNT=3
GKE_MACHINE_TYPE=n2-standard-2

## Vertex AI Configuration
VERTEX_AI_LOCATION=europe-west2
VERTEX_AI_MODEL=gemini-pro

## Secrets (use Secret Manager)
# - database-password
# - api-secret-key
# - jwt-secret-key

## Service Accounts
# - nexus-crm-sa@${PROJECT}.iam.gserviceaccount.com
#   Roles: Cloud SQL Client, Storage Object Admin, Vertex AI User
