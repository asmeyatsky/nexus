# Nexus CRM Environment Variables
# Copy to .env and fill in values

# App
ENVIRONMENT=development
DEBUG=true

# Security
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_256_BIT_KEY

# Database
DATABASE_URL=postgresql://nexus:password@localhost:5432/nexus_crm

# Redis
REDIS_URL=redis://localhost:6379

# GCP
GCP_PROJECT_ID=
GCP_REGION=europe-west2

# SSO - Google
SSO_GOOGLE_CLIENT_ID=
SSO_GOOGLE_CLIENT_SECRET=

# SSO - Azure AD
SSO_AZURE_CLIENT_ID=
SSO_AZURE_CLIENT_SECRET=
SSO_AZURE_TENANT_ID=

# SSO - Okta
SSO_OKTA_DOMAIN=
SSO_OKTA_API_KEY=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# External Services
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SENDGRID_API_KEY=
MAILCHIMP_API_KEY=
